
// Demonstrate function inlining with lix 

import bytecodeoptimizer

fn first(a) {
    return a[0]
}

fn last(List a) {
    return a[-1]
}

fn extract(List a, b) {
    return a[b]
}

{
    var a = [1, 2]
    print first(a) // expect: 1
    print last(a)  // expect: 2
    //print extract(a, 1) // expect: 2

