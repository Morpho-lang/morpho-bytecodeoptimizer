import bytecodeoptimizer
// Minimal probe for LIX remapping. This isolates custom indexing through
// vm_invoke(index, ...) without the rest of the plotfield arithmetic.

class Selection {
  index(g, i) {
    if (g==0) return i!=1
    else return i==1
  }
}

fn probe(sel) {
  for (g in 0...2) {
    for (i in 0...3) {
      print sel[g, i]
    }
  }
}

probe(Selection())
// expect: true
// expect: false
// expect: true
// expect: false
// expect: true
// expect: false
